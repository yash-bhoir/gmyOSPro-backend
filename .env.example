NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gymos

# JWT — use long random strings in production
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12
OTP_EXPIRY_MINUTES=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# SMS — MSG91 (for real OTP delivery)
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
# MSG91_SENDER_ID=GYMOSS

# Payments — Razorpay
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
